# ---------------------------------------------------------------------------
# Copy this file to `.env` for local development:  cp .env.example .env
#
# On Hugging Face, DON'T upload .env. Instead set these in your Space:
#   Settings -> Variables and secrets
#     - Public, non-sensitive values  -> "Variables"
#     - Tokens / anything secret       -> "Secrets"
# ---------------------------------------------------------------------------

# --- Identity -------------------------------------------------------------
# Shown in the page title and used as the bot's persona in the system prompt.
RESEARCHER_NAME="Your Name"

# --- Connection to your local LLM ----------------------------------------
# The PUBLIC URL of the tunnel pointing at your machine's Ollama server.
# After you start zrok (see docs/03-local-gpu-and-tunnel.md) it prints a URL
# like https://researchbot.share.zrok.io — paste that here.
# For purely local testing without a tunnel, use http://localhost:11434
OLLAMA_BASE_URL="https://your-tunnel-name.share.zrok.io"

# The exact Ollama model tag you pulled, e.g. qwen3:8b, llama3.1:8b, mistral:7b
OLLAMA_MODEL="qwen3:8b"

# Header that tells zrok to skip its interstitial page. Leave as-is for zrok;
# set to empty ("") if you use a different tunnel (Cloudflare, ngrok, etc.).
TUNNEL_SKIP_HEADER="skip_zrok_interstitial"

# --- Retrieval / generation tuning ---------------------------------------
# Embedding model that runs on the Space CPU. Keep it small.
EMBED_MODEL_NAME="BAAI/bge-small-en-v1.5"

# 0.0 = most factual/deterministic, 1.0 = most creative. Research Q&A wants low.
LLM_TEMPERATURE="0.3"

# Token budget per LLM request.
CONTEXT_WINDOW="8192"

# Seconds before giving up on the local GPU.
REQUEST_TIMEOUT="120.0"

# --- Optional: log every question to a PRIVATE Hugging Face Dataset -------
# Leave empty to disable logging entirely. To enable, create a private dataset
# (e.g. yourname/researchbot-logs) and add an HF_TOKEN secret with write access.
LOG_DATASET=""
